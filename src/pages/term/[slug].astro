---
import { getCollection, getEntry } from 'astro:content';
import { marked } from 'marked';
import BaseLayout from '../../layouts/BaseLayout.astro';

marked.setOptions({ gfm: true, breaks: false });
const md = (s: string | undefined): string => (s ? (marked.parse(s) as string) : '');

export async function getStaticPaths() {
  const terms = await getCollection('terms');
  return terms.map((term) => ({
    params: { slug: term.data.slug },
    props: { term },
  }));
}

const { term } = Astro.props;

// Resolve category references to their display data.
const categoryEntries = await Promise.all(
  term.data.categories.map((ref) => getEntry(ref))
);
const categories = categoryEntries.filter((c): c is NonNullable<typeof c> => !!c);

// Resolve related term references.
const relatedEntries = term.data.relatedTerms
  ? await Promise.all(
      term.data.relatedTerms.map((ref) => getEntry(ref))
    )
  : [];
const related = relatedEntries.filter((t): t is NonNullable<typeof t> => !!t);

const dateString = term.data.lastUpdated.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---
<BaseLayout
  title={term.data.name}
  description={term.data.plainEnglish}
>
  <p class="muted" style="margin-bottom: 0.25rem;">
    <a href="/">Home</a> / <a href="/a-z">A–Z</a>
  </p>
  <h1>{term.data.name}</h1>

  <div class="term-meta">
    Categories:{' '}
    {categories.map((cat) => (
      <a href={`/category/${cat.data.slug}`} class="category-pill">{cat.data.name}</a>
    ))}
    {' '}· Last updated {dateString}
  </div>

  <section class="section-block">
    <h2>Plain English</h2>
    <Fragment set:html={md(term.data.plainEnglish)} />
  </section>

  <section class="section-block">
    <h2>Detailed Explanation</h2>
    <Fragment set:html={md(term.data.detailedExplanation)} />
  </section>

  {term.data.workedExample && (
    <section class="section-block">
      <h2>Worked Example</h2>
      <Fragment set:html={md(term.data.workedExample)} />
    </section>
  )}

  {term.data.usedInSentence && (
    <section class="section-block">
      <h2>Used in a Sentence</h2>
      <p class="quote">{term.data.usedInSentence}</p>
    </section>
  )}

  {term.data.whenItApplies && (
    <section class="section-block">
      <h2>When It Applies</h2>
      <Fragment set:html={md(term.data.whenItApplies)} />
    </section>
  )}

  {term.data.commonMistakes && (
    <section class="section-block">
      <h2>Common Mistakes</h2>
      <Fragment set:html={md(term.data.commonMistakes)} />
    </section>
  )}

  {term.data.howToRemember && (
    <section class="section-block">
      <h2>How to Remember It</h2>
      <Fragment set:html={md(term.data.howToRemember)} />
    </section>
  )}

  {term.data.whenToConsult && (
    <section class="section-block">
      <h2>When to Talk to a Professional</h2>
      <Fragment set:html={md(term.data.whenToConsult)} />
    </section>
  )}

  {term.data.faqs && term.data.faqs.length > 0 && (
    <section class="section-block">
      <h2>FAQs</h2>
      {term.data.faqs.map((faq) => (
        <div class="faq-item">
          <p class="q">{faq.question}</p>
          <Fragment set:html={md(faq.answer)} />
        </div>
      ))}
    </section>
  )}

  {related.length > 0 && (
    <section class="section-block">
      <h2>Related Terms</h2>
      <ul class="related">
        {related.map((r) => (
          <li><a href={`/term/${r.data.slug}`}>{r.data.name}</a></li>
        ))}
      </ul>
    </section>
  )}

</BaseLayout>
